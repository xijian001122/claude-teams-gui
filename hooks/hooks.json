{
  "description": "Claude Teams GUI hooks - Auto-start GUI servers and real-time task notifications",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/session-start.js",
            "timeout": 30
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/task-created.js",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
